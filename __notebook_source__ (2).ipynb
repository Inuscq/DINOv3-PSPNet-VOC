    def forward(self, x):
        h, w = x.shape[2:]
        feats = [x]
        for p, c in zip(self.pools, self.convs):
            y = self.act(c(p(x)))
            y = F.interpolate(y, size=(h, w), mode="bilinear", align_corners=True)
            feats.append(y)
        return torch.cat(feats, dim=1)

